<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Rapport hebdomadaire – {{ market_name }} – {{ period.current_week.start }}</title>
<style>{{ base_css }}</style>
</head>
<body>
<div class="report">
  <div class="report-header">
    <div class="brand">{{ brand_name }} · Rapport hebdomadaire e-commerce</div>
    <h1>{{ market_name }} ({{ market_code }})</h1>
    <div class="period">
      Semaine du {{ period.current_week.start }} au {{ period.current_week.end }}
      &nbsp;·&nbsp; vs S-1 : {{ period.previous_week.start }} – {{ period.previous_week.end }}
      &nbsp;·&nbsp; vs même semaine l'an dernier : {{ period.same_week_last_year.start }} – {{ period.same_week_last_year.end }}
    </div>
  </div>

  <section class="scorecards">
    {% for card in scorecards %}
    <div class="stat-tile">
      <div class="label">{{ card.label }}</div>
      <div class="value">
        {%- if card.kind == 'money' -%}{{ card.value | money_fmt(currency) }}
        {%- elif card.kind == 'rate' -%}{{ '%.2f'|format(card.value) }}%
        {%- else -%}{{ card.value | int_fmt }}
        {%- endif -%}
      </div>
      <div class="deltas">
        <span class="delta {{ 'good' if card.vs_lw >= 0 else 'bad' }}">{{ '▲' if card.vs_lw >= 0 else '▼' }} {{ card.vs_lw | pct_fmt }}<span class="vs-label">vs LW</span></span>
        <span class="delta {{ 'good' if card.vs_ly >= 0 else 'bad' }}">{{ '▲' if card.vs_ly >= 0 else '▼' }} {{ card.vs_ly | pct_fmt }}<span class="vs-label">vs LY</span></span>
      </div>
    </div>
    {% endfor %}
  </section>

  <section>
    <h2>Trafic — 6 derniers mois vs année précédente</h2>
    <div class="card">{{ trend_chart_svg }}</div>
  </section>

  <section class="two-col">
    <div>
      <h2>Top Pages</h2>
      <table>
        <thead>
          <tr><th>Page</th><th class="num">Sessions</th><th class="num">Engagement moy.</th><th class="num">vs LW</th><th class="num">vs LY</th></tr>
        </thead>
        <tbody>
        {% for page in top_pages %}
          <tr>
            <td class="main-cell">{{ page.url }}</td>
            <td class="num">{{ page.sessions | int_fmt }}</td>
            <td class="num">{{ '%.0f'|format(page.engagement_time_avg_sec) }}s</td>
            <td class="num delta {{ 'good' if page.sessions_vs_lw_pct >= 0 else 'bad' }}">{{ page.sessions_vs_lw_pct | pct_fmt }}</td>
            <td class="num delta {{ 'good' if page.sessions_vs_ly_pct >= 0 else 'bad' }}">{{ page.sessions_vs_ly_pct | pct_fmt }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
    <div>
      <h2>Traffic Sources</h2>
      <div class="card">{{ traffic_donut_svg }}</div>
    </div>
  </section>

  <section>
    <h2>Détail Traffic Sources (10 canaux)</h2>
    <table>
      <thead><tr><th>Canal</th><th class="num">Sessions</th><th class="num">% du trafic</th><th class="num">vs LW</th></tr></thead>
      <tbody>
      {% for src in traffic_sources %}
        <tr>
          <td class="main-cell">{{ src.channel }}</td>
          <td class="num">{{ src.sessions | int_fmt }}</td>
          <td class="num">{{ '%.1f'|format(src.pct_of_total) }}%</td>
          <td class="num delta {{ 'good' if src.sessions_vs_lw_pct >= 0 else 'bad' }}">{{ src.sessions_vs_lw_pct | pct_fmt }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  <section>
    <h2>Top Products (jointure Shopify × GA4 par SKU)</h2>
    <table>
      <thead>
        <tr><th>Produit</th><th>SKU</th><th class="num">Units</th><th class="num">Net Sales</th><th class="num">Sessions PDP</th><th class="num">Conv.</th></tr>
      </thead>
      <tbody>
      {% for p in top_products %}
        <tr>
          <td class="main-cell">{{ p.product_name }}</td>
          <td>{{ p.sku }}</td>
          <td class="num">{{ p.units | int_fmt }}</td>
          <td class="num">{{ p.net_sales | money_fmt(currency) }}</td>
          <td class="num">{{ p.sessions | int_fmt }}</td>
          <td class="num">{{ '%.2f'|format(p.conversion_rate_pct) }}%</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>

    {% if mapping_log.unmatched_shopify_count or mapping_log.unmatched_ga4_count %}
    <div class="mapping-log" style="margin-top:12px;">
      <strong>Mapping produit ↔ page GA4 : {{ mapping_log.unmatched_shopify_count + mapping_log.unmatched_ga4_count }} cas non rapproché(s) automatiquement — à traiter manuellement.</strong>
      {% if mapping_log.unmatched_shopify_products %}
        <div style="margin-top:6px;">Produits Shopify sans page GA4 trouvée : {% for i in mapping_log.unmatched_shopify_products %}{{ i.sku }} ({{ i.product_name }}){% if not loop.last %}, {% endif %}{% endfor %}</div>
      {% endif %}
      {% if mapping_log.unmatched_ga4_pages %}
        <div style="margin-top:4px;">Pages GA4 sans produit Shopify correspondant : {% for i in mapping_log.unmatched_ga4_pages %}{{ i.url }}{% if not loop.last %}, {% endif %}{% endfor %}</div>
      {% endif %}
    </div>
    {% endif %}
  </section>

  <div class="footer-note">Généré automatiquement le {{ generated_at }} · Données 100% synthétiques (proof of product, aucune donnée réelle) · {{ brand_name }}</div>
</div>
</body>
</html>
